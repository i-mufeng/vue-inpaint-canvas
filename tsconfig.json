{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noUncheckedIndexedAccess": true,
    "jsx": "preserve",
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "types": ["vite/client"],
    "paths": {
      "vue-inpaint-canvas": ["./src/vue/index.ts"],
      "vue-inpaint-canvas/core": ["./src/core/index.ts"]
    }
  },
  "include": ["src", "playground", "tests", "vite.config.ts"],
  "exclude": ["dist", "node_modules"]
}
