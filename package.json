{
  "name": "vue-inpaint-canvas",
  "version": "0.1.1",
  "description": "Framework-agnostic core + Vue 3 component for inpaint mask painting, cropping, and light adjustments — purpose-built for AI image editing (gpt-image / Stable Diffusion inpainting). Exports transparent-alpha PNG masks per the OpenAI images/edits convention.",
  "type": "module",
  "license": "MIT",
  "author": "Mufeng",
  "homepage": "https://github.com/i-mufeng/vue-inpaint-canvas#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/i-mufeng/vue-inpaint-canvas.git"
  },
  "bugs": {
    "url": "https://github.com/i-mufeng/vue-inpaint-canvas/issues"
  },
  "keywords": [
    "vue",
    "vue3",
    "inpaint",
    "inpainting",
    "mask",
    "canvas",
    "konva",
    "image-editor",
    "image-mask",
    "ai",
    "gpt-image",
    "stable-diffusion",
    "crop",
    "brush"
  ],
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=18.12"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "README.zh-CN.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core.js"
    },
    "./style.css": "./dist/style.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && vue-tsc -p tsconfig.build.json",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "prepublishOnly": "bun run lint && bun run typecheck && bun run test && bun run build"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {
    "konva": "^10.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "canvas": "^3.2.3",
    "jsdom": "^29.1.1",
    "oxlint": "^1.69.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vue": "^3.5.38",
    "vue-tsc": "^3.3.5"
  }
}
